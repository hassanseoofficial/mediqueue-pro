# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/mediqueue

# ─── Redis (leave empty to use in-memory fallback for local dev) ─
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-very-long-random-256-bit-secret
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=another-long-random-secret-for-refresh
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Twilio SMS (optional for local dev — leave blank to console-log) ─
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Email / SendGrid (optional) ────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@mediqueue.app

# ─── Supabase (production only) ─────────────────────────────────
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
